{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@assets": ["src/assets"],
      "@assets/*": ["src/assets/*"],

      "@components": ["src/components"],
      "@components/*": ["src/components/*"],

      "@config": ["src/config"],
      "@config/*": ["src/config/*"],

      "@contexts": ["src/contexts"],
      "@contexts/*": ["src/contexts/*"],

      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],

      "@layouts": ["src/layouts"],
      "@layouts/*": ["src/layouts/*"],

      "@pages": ["src/pages"],
      "@pages/*": ["src/pages/*"],

      "@routes": ["src/routes"],
      "@routes/*": ["src/routes/*"],

      "@services": ["src/services"],
      "@services/*": ["src/services/*"],

      "@styles": ["src/styles"],
      "@styles/*": ["src/styles/*"],

      "@utils": ["src/utils"],
      "@utils/*": ["src/utils/*"]
    }
  }
}